[sub_resource type="GDScript" id="GDScript_1bvp3"]
script/source = "extends Node2D

@onready var slime_node = %Slime 
@onready var slime_sprite = %Slime/SlimeSprite
@onready var slime_hp_bar = %SlimeHealthBar
@onready var attack_bar = %SlimeAttackBar

var current_slime_hp: int = 0
var current_slime_data: SlimeData

func _ready():
	# Start the game with a slime from the current zone
	spawn_new_slime()

func spawn_new_slime():
	var zone = GameData.current_zone
	
	# 1. Pick a random slime from the zone's list
	var random_index = randi() % zone.possible_slimes.size()
	current_slime_data = zone.possible_slimes[random_index]
	GameData.current_slime = current_slime_data
	
	# 2. Reset the health and timer based on the new data
	current_slime_hp = current_slime_data.health
	
	# 3. Update the Visuals of the existing node
	slime_sprite.texture = current_slime_data.texture
	slime_hp_bar.max_value = current_slime_data.health
	slime_hp_bar.value = current_slime_hp
	
	# Reset the attack bar (if you use one)
	attack_bar.max_value = current_slime_data.attack_speed
	attack_bar.value = current_slime_data.attack_speed
	
	# Make sure the slime is visible again
	slime_node.visible = true
	print(\"A \" + current_slime_data.name + \" appeared!\")

# Call this function when you click the slime
func take_damage(amount: int):
	current_slime_hp -= amount
	slime_hp_bar.value = current_slime_hp
	
	if current_slime_hp <= 0:
		on_slime_defeated()

func on_slime_defeated():
	# Hide the slime so it looks like it died
	slime_node.visible = false
	
	# 1. Handle Loot logic
	var roll = randf()
	if roll < GameData.get_chest_drop_chance():
		spawn_chest()
	else:
		# Standard crystal drop from SlimeData
		var crystals = randi_range(current_slime_data.crystal_drop_min, current_slime_data.crystal_drop_max)
		GameData.slime_crystals += crystals * GameData.current_zone.crystal_multiplier
	
	# 2. Wait 0.5s and then just \"Reset\" the same node with new data
	await get_tree().create_timer(0.5).timeout
	spawn_new_slime()

func spawn_chest():
	# Since we aren't instantiating a chest scene, we just show a message or a popup
	print(\"Chest appeared!\")
	roll_chest_loot()
	
func roll_chest_loot():
	var special_found = 0
	var rolls = 3 + (GameData.luck / 20) 
	for i in range(rolls):
		if randf() < 0.20:
			special_found += 1
			
	GameData.special_crystals += special_found
	GameData.slime_crystals += 100 
	print(\"Found \", special_found, \" Special Crystals!\")
	
func _on_pause_button_pressed():
	get_tree().paused = !get_tree().paused
	$UI/UpgradeMenu.visible = get_tree().paused

func _on_slime_attack_timer_timeout():
	# Slime hits player
	GameData.player_hp -= 10
	if GameData.player_hp <= 0:
		get_tree().paused = !get_tree().paused
		
"

